# ── Required ──────────────────────────────────────────────────
# Groq API key — get it free at https://console.groq.com/keys
GROQ_API_KEY=gsk_your-key-here

# ── Free: Real data (highly recommended) ──────────────────────
# Google Places API — $200/month free credit (covers ~100k requests)
# 1. Go to https://console.cloud.google.com
# 2. Create a project → Enable "Places API"
# 3. APIs & Services → Credentials → Create API Key
GOOGLE_PLACES_API_KEY=your-google-places-key-here
